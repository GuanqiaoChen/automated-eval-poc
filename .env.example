# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# -- Required ------------------------------------------------------------------

# Your Character AI authentication token.
# How to get it:
#   1. Open https://character.ai in Chrome and log in.
#   2. Open DevTools (F12) → Application → Cookies → https://character.ai
#   3. Copy the value of the key named  char_token
# OR:
#   1. Open DevTools → Network tab → filter by "trpc"
#   2. Click any request → Headers → Request Headers
#   3. Copy the value after  "Authorization: Token "
CAI_TOKEN=your_character_ai_token_here

# Google API key for Gemini (used by ADK agents).
# Get one free at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# -- Optional ------------------------------------------------------------------

# Character AI character ID (from the URL: character.ai/chat/<CHARACTER_ID>)
# Default below is Geto Suguru from Jujutsu Kaisen, you can change it to any character you want to test against.
CAI_CHARACTER_ID=njwPV5eqUYcuwtFQfQANxVhyvwpjv3c64UrZm5O5h18

# Gemini model used by ADK agents
GEMINI_MODEL=gemini-flash-latest

# Run Playwright browser in headless mode (true/false)
PLAYWRIGHT_HEADLESS=true

# Appium server URL (for mobile strategy)
APPIUM_SERVER_URL=http://localhost:4723

# ADB device name (run `adb devices` to find yours)
APPIUM_DEVICE_NAME=emulator-5554
